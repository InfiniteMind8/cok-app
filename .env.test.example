# ─── E2E Test Environment ────────────────────────────────────────────────────
# Copy this file to .env.test and fill in the values.
# Never commit .env.test — it contains secrets.
#
# Required for E2E tests (pnpm test:e2e):

# ── Database ─────────────────────────────────────────────────────────────────
# Must be a dedicated TEST database — global-setup will run migrations + seed.
DATABASE_URL="postgresql://user:pass@host:5432/cok_test?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/cok_test?sslmode=require"

# ── Clerk (test Clerk instance recommended) ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ── Demo mode (REQUIRED for auth in E2E tests) ────────────────────────────────
NEXT_PUBLIC_DEMO_MODE_ENABLED="true"

# ── Optional: Rate limiting (omit to use in-memory fallback) ──────────────────
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ── Optional: Resend (omit to skip actual email delivery in tests) ─────────────
# RESEND_API_KEY="re_..."

# ── Optional: UploadThing (omit to skip companion zip uploads) ────────────────
# UPLOADTHING_TOKEN="..."

# ── Sentry (omit DSN to disable in test runs) ────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── Cron secret (can be any string in test) ───────────────────────────────────
CRON_SECRET="e2e-test-secret"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED="1"
