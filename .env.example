# City of Karis — Community App — Environment Variables
# Copy this to .env.local and fill in your values.

# --- Supabase PostgreSQL ---
# Get from: https://supabase.com → Project Settings → Database
# Use the "Connection Pooler" string for DATABASE_URL (port 6543, pgbouncer=true)
# Use the "Direct connection" string for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Clerk Authentication ---
# Get from: https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# Clerk redirect configuration (these values work with the current route structure)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Resend (transactional email) ---
# Get from: https://resend.com/api-keys
# See docs/email-setup.md for full DNS verification and domain setup instructions
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@cityofkaris.com"
RESEND_FROM_NAME="City of Karis"

# --- Uploadthing (file uploads) ---
# Get from: https://uploadthing.com/dashboard → API Keys
UPLOADTHING_TOKEN="eyJ..."

# --- Demo mode ---
# Set to "true" to show six one-click demo-account buttons on the sign-in page.
# Set to "false" (or omit) for production — no demo elements are rendered at all.
NEXT_PUBLIC_DEMO_MODE_ENABLED="false"

# --- Sentry Error Monitoring ---
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN is used client-side.
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# Deployment environment tag (development | staging | production)
DEPLOY_ENV="development"
NEXT_PUBLIC_DEPLOY_ENV="development"

# Git SHA for release tagging — set automatically in CI (e.g. $VERCEL_GIT_COMMIT_SHA)
# Leave blank for local dev (falls back to "dev")
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""

# Auth token for source map upload (CI only — not needed for runtime)
# Get from: https://sentry.io → Settings → Auth Tokens
# Scope: project:releases, org:read
SENTRY_AUTH_TOKEN=""

# Sentry org and project slugs (used by withSentryConfig for source map upload)
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="cok-community-app"

# --- Rate limiting (Upstash Redis) ---
# Get from: https://console.upstash.com → Create database → REST API
# IMPORTANT: Without these vars, the rate limiter falls back to an in-memory store
# (process-scoped, resets on restart). In-memory limits do NOT enforce across
# edge middleware isolates in production — Redis is required for reliable auth rate limiting.
UPSTASH_REDIS_REST_URL="https://YOUR_DB.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXXXxxxxxxxxxxxxxxxxxxxxxxxxxx"
